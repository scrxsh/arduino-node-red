//------------------------------------------------------------------SERVOMOTORES----------------------------------------------------------------------------------//
#include <Servo.h>
Servo s1;
Servo s2;
//------------------------------------------------------------------SENSOR TEMPERATURA Y HUMEDAD------------------------------------------------------------------------//
#include <DHT.h>
const int stemp=A0;
int temp;
int hum;
DHT dht (stemp, DHT11);
//-----------------------------------------------------------------SENSOR ULTRASONICO------------------------------------------------------------------------------------//
long dis;
long tmp;
//-----------------------------------------------------------------SENSOR DE GAS METANO---------------------------------------------------------------------------------//
const int AOUTpin = A1;
const int DOUTpin = 7;
int vg;
int l;
//----------------------------------------------------------------SENSOR DE FUEGO-------------------------------------------------------------------------------------//
int sf =0;
int vf =6;
//--------------------------------------------------------------LEDS Y BLUETOOTH----------------------------------------------------------------------------------------//
int l1=13;
int l2=12;
int eb = 0;

void setup (){
Serial.begin(9600);
//--------------------------------------------------------------------SERVOMOTORES------------------------------------------------------------------------------------------//
s1.attach(11,600,1500);
s2.attach(10,600,1500);
//--------------------------------------------------------------------SENSOR TEMPERATURA Y HUMEDAD------------------------------------------------------------------------//
dht.begin();
//-----------------------------------------------------------------SENSOR ULTRASONICO------------------------------------------------------------------------------------//
pinMode (9, OUTPUT);//TRIGGER  
pinMode (8, INPUT);//ECHO
//--------------------------------------------------------------SENSOR DE GAS METANO----------------------------------------------------------------------------------//
pinMode (DOUTpin, INPUT);
//--------------------------------------------------------------SENSOR DE FUEGO----------------------------------------------------------------------------------------//
pinMode (vf, OUTPUT);
//--------------------------------------------------------------LEDS----------------------------------------------------------------------------------------------//
pinMode (13, OUTPUT);
pinMode (12, OUTPUT);
}

void loop (){
//-----------------------------------------------------------------SENSOR DE TEMPERATURA Y HUMEDAD-------------------------------------------------------------------//
  hum = dht.readHumidity();
  temp = dht.readTemperature();
//-----------------------------------------------------------------SENSOR ULTRASONICO---------------------------------------------------------------------------------//
  digitalWrite(9, LOW);
  delayMicroseconds (5);
  digitalWrite(8, HIGH);
  delayMicroseconds (10);
  tmp = pulseIn (9, HIGH);
  dis = long(0.017*temp);
//--------------------------------------------------------------SENSOR DE GAS METANO---------------------------------------------------------------------------------//
 vg = analogRead(AOUTpin);
 l= digitalRead(DOUTpin);
//-------------------------------------------------------------------SENSOR DE FUEGO-------------------------------------------------------------------------------//
sf = analogRead(A2);

//-----------------------------------------------------------MONITOR SERIAL APP-------------------------------------------------------------------------------------//
  Serial.println("temp&,hum&,dis&,vg&,sf&");
  delay (500);
//------------------------------------------------------------------ACTIVACION DE SERVOMOTORES--------------------------------------------------------------------//
if (Serial.available ()>0){
eb = Serial.read();
}

switch (eb){

case 'a':
digitalWrite(l1,HIGH);
break;

case 'b':
digitalWrite(l1,LOW);
break;

case 'c':
digitalWrite(l2,HIGH);
break;

case 'd':
digitalWrite(l2,LOW);
break;


case 'e':
s1.write (0);
delay (700);
s1.write (90);
delay (700);
s1.write (180);
delay (700);
break;

case 'f':
s1.write (0);
break;

case 'g':
s2.write (0);
delay (700);
s2.write (90);
delay (700);
s2.write (180);
delay (700);
break;

case 'h':
s2.write (0);
break;
}

}


