        "func": "//Creacion de variable para almacenar json\nvar newMsg = {};\n//Copiar los datos del JSON\nnewMsg.payload = msg.payload;\n\nvar ultrasonido = {}\nvar humedad = {}\nvar temperatura = {}\nvar pir = {}\nvar servo = {}\nvar fecha = {}\n\nultrasonido.payload = newMsg.payload.sistema_monitoreo.sensores[0].distancia;\nhumedad.payload = newMsg.payload.sistema_monitoreo.sensores[1].datos_obtenidos.humedad;\ntemperatura.payload = newMsg.payload.sistema_monitoreo.sensores[1].datos_obtenidos.temperatura;\npir.payload = newMsg.payload.sistema_monitoreo.sensores[2].estado;\nservo.payload = newMsg.payload.sistema_monitoreo.actuadores[0].angulo_giro;\nfecha.payload = newMsg.payload.sistema_monitoreo.fecha;\n\nlet mensaje = `🤖 𝗥𝗘𝗣𝗢𝗥𝗧𝗘 𝗗𝗘 𝗦𝗘𝗡𝗦𝗢𝗥𝗘𝗦 🤖\n───────────────────\n📏 𝗗𝗶𝘀𝘁𝗮𝗻𝗰𝗶𝗮: ${ultrasonido.payload} cm\n🌡️ 𝗧𝗲𝗺𝗽𝗲𝗿𝗮𝘁𝘂𝗿𝗮: ${temperatura.payload}°C\n💧 𝗛𝘂𝗺𝗲𝗱𝗮𝗱: ${humedad.payload}%\n👁️ 𝗦𝗲𝗻𝘀𝗼𝗿 𝗣𝗜𝗥: ${pir.payload}\n⚙️ Á𝗻𝗴𝘂𝗹𝗼 𝗱𝗲 𝘀𝗲𝗿𝘃𝗼: ${servo.payload}°\n🕒 𝗙𝗲𝗰𝗵𝗮: ${fecha.payload}\n───────────────────`;\n\nnewMsg.payload = {\n        \"chatId\": 1114502551,\n        \"type\":\"message\",\n        \"content\": mensaje\n    }\nreturn newMsg;\n\n\n",
