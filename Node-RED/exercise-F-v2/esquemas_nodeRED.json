    {
        "id": "1fb505a758f56236",
        "type": "function",
        "z": "d660842d98786b7b",
        "name": "Inserción de información a la BD",
        "func": "//Creacion de variable para almacenar json\nvar newMsg = {};\n//Copiar los datos del JSON\nlet ultrasonido = msg.payload.sistema_monitoreo.sensores[0].distancia;\nlet humedad = msg.payload.sistema_monitoreo.sensores[1].datos_obtenidos.humedad;\nlet temperatura = msg.payload.sistema_monitoreo.sensores[1].datos_obtenidos.temperatura;\nlet pir = msg.payload.sistema_monitoreo.sensores[2].estado;\nlet servo = msg.payload.sistema_monitoreo.actuadores[0].angulo_giro;\nlet fecha = msg.payload.sistema_monitoreo.fecha;\n\nnewMsg.topic = \"INSERT INTO `sistema_monitoreo`.`ultrasonido` (`distancia`, `fecha`, `dispositivos_id`) VALUES ('\"+ ultrasonido +\"', '\"+ fecha +\"', '1');\" + \n\"INSERT INTO `sistema_monitoreo`.`dht11` (`humedad`, `temperatura`, `fecha`, `dispositivos_id`) VALUES ('\" + humedad + \"', '\" + temperatura +\"', '\"+ fecha +\"', '2');\" + \n\"INSERT INTO `sistema_monitoreo`.`pir` (`estado`, `fecha`, `dispositivos_id`) VALUES ('\" + pir +\"', '\" + fecha +\"', '3');\" + \n\"INSERT INTO `sistema_monitoreo`.`servo` (`estado`, `fecha`, `dispositivos_id`) VALUES ('\"+ servo +\"', '\" + fecha +\"', '4');\";\n\nnewMsg.payload = [humedad, temperatura, ultrasonido, pir, servo, fecha]\nreturn newMsg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 590,
        "y": 160,
        "wires": [
